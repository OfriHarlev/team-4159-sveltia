---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
	const pages = await getCollection("pages");
	return pages.map((page) => ({
		params: { slug: page.id },
		props: { page },
	}));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<Base title={page.data.title} description={page.data.description}>
	<article class="page-article">
		<header class="page-header">
			<div class="page-kicker">
				<span class="page-num">/</span>
				<span class="page-label">{page.id.replace(/-/g, " ")}</span>
			</div>
			<h1 class="page-title">{page.data.title}</h1>
			<hr class="page-rule" />
		</header>

		<div class="page-content">
			<div class="wp-imported"><Content /></div>
		</div>
	</article>
</Base>

<style>
	.page-article {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: clamp(72px, 12vh, 140px) clamp(24px, 5vw, 80px) clamp(80px, 12vh, 140px);
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 3fr);
		gap: clamp(24px, 6vw, 80px);
	}
	@media (max-width: 780px) { .page-article { grid-template-columns: 1fr; } }
	.page-header { grid-column: 1 / -1; margin-bottom: clamp(32px, 6vh, 60px); }
	.page-kicker {
		display: flex; gap: 10px; align-items: baseline;
		font-family: var(--font-mono);
		font-size: 11px; font-weight: 500; letter-spacing: 0.18em;
		text-transform: uppercase; color: var(--color-muted); margin-bottom: 18px;
	}
	.page-num { color: var(--cardinal-bright); }
	.page-title {
		font-family: var(--font-display); font-weight: 400;
		font-size: clamp(44px, 8vw, 120px); line-height: 0.95;
		letter-spacing: -0.025em; margin: 0 0 24px 0; color: var(--color-text);
	}
	.page-rule { border: 0; height: 1px; background: var(--color-border); margin: 0; }
	.page-content { grid-column: 2; max-width: 780px; }
	@media (max-width: 780px) { .page-content { grid-column: 1; } }

	.wp-imported { font-size: 17px; line-height: 1.65; color: var(--color-text-secondary); }
	.wp-imported :global(h1), .wp-imported :global(h2), .wp-imported :global(h3), .wp-imported :global(h4) {
		font-family: var(--font-display); font-weight: 400; line-height: 1.1;
		letter-spacing: -0.02em; color: var(--color-text); margin: 1.6em 0 0.4em;
	}
	.wp-imported :global(h1) { font-size: clamp(32px, 4vw, 52px); }
	.wp-imported :global(h2) { font-size: clamp(28px, 3vw, 40px); font-style: italic; }
	.wp-imported :global(h3) { font-size: clamp(22px, 2.2vw, 28px); }
	.wp-imported :global(p) { margin: 0 0 1.2em; }
	.wp-imported :global(p:first-of-type) { font-size: 20px; line-height: 1.5; color: var(--color-text); }
	.wp-imported :global(a) { color: var(--cardinal-bright); text-decoration: none; border-bottom: 1px solid color-mix(in srgb, var(--cardinal-bright) 40%, transparent); }
	.wp-imported :global(a:hover) { border-bottom-color: var(--cardinal-bright); }
	.wp-imported :global(img) { max-width: 100%; height: auto; display: block; margin: 2em 0; border: 1px solid var(--color-border-subtle); }
	.wp-imported :global(figure) { margin: 2em 0; }
	.wp-imported :global(figure img) { margin: 0; }
	.wp-imported :global(ul), .wp-imported :global(ol) { margin: 0 0 1.2em; padding-left: 24px; }
	.wp-imported :global(li) { margin-bottom: 0.4em; }
	.wp-imported :global(ul li::marker) { color: var(--cardinal-bright); }
	.wp-imported :global(iframe) { max-width: 100%; aspect-ratio: 16 / 9; height: auto; border: 1px solid var(--color-border-subtle); margin: 2em 0; display: block; }
	.wp-imported :global(blockquote) {
		margin: 2em 0; padding: 0 0 0 24px;
		border-left: 2px solid var(--cardinal-bright);
		font-family: var(--font-display); font-size: 22px; font-style: italic; line-height: 1.3;
		color: var(--color-text);
	}
	.wp-imported :global(strong), .wp-imported :global(b) { color: var(--color-text); font-weight: 600; }
</style>
